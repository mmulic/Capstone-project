# ============================================
# Disaster Assessment Backend — Environment Config
# Copy this to .env and fill in your values
# ============================================

# --- App ---
APP_NAME=disaster-assessment-api
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres_dev_password
DATABASE_NAME=disaster_assessment
DATABASE_URL=postgresql+asyncpg://postgres:postgres_dev_password@db:5432/disaster_assessment

# --- AWS S3 (leave empty for local dev — uses mock) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=disaster-assessment-images

# --- JWT Auth ---
JWT_SECRET_KEY=dev-secret-change-in-production-!!!
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google Gemini (ML person fills this in) ---
GEMINI_API_KEY=

# --- Rate Limiting ---
RATE_LIMIT_PREDICT=10/minute
RATE_LIMIT_CHAT=30/minute
